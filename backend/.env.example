NODE_ENV=development
PORT=5000
APP_VERSION=1.0.0
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cybersec
JWT_ACCESS_SECRET=replace_access_secret
JWT_REFRESH_SECRET=replace_refresh_secret
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_API_KEY=replace_with_shared_secret
AI_SERVICE_TIMEOUT_MS=5000
AI_TIMEOUT_ALERT_THRESHOLD=10
FRONTEND_ORIGIN=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000
TRUST_PROXY=false
ENFORCE_CSRF=false
CSRF_COOKIE_SECURE=false
CSRF_COOKIE_SAMESITE=lax
RATE_LIMIT_GENERAL_MAX=300
RATE_LIMIT_AUTH_MAX=30
RATE_LIMIT_UPLOAD_MAX=60
REQUIRE_STRONG_SECRETS=false
LOG_LEVEL=info
DEFAULT_TENANT_ID=default
ALLOW_ADMIN_TENANT_OVERRIDE=true
SUPER_ADMIN_EMAILS=
SCHEDULER_ENABLED=true
SCHEDULER_TICK_SECONDS=60
SEARCH_JOB_CRON=* * * * *
AUTO_THREAT_SCAN_ENABLED=true
AUTO_THREAT_SCAN_CRON=*/5 * * * *
AUTO_THREAT_SCAN_BATCH_SIZE=200
ALERT_ESCALATION_ENABLED=true
ALERT_ESCALATION_CRON=*/5 * * * *
ALERT_ESCALATION_MINUTES=15
ALERT_ESCALATION_SEVERITIES=HIGH,CRITICAL
ALERT_ESCALATION_TARGET_SEVERITY=CRITICAL
ALERT_ESCALATION_MAX_PER_RUN=100