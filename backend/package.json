{
  "name": "cybersec-platform-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "seed": "node prisma/seed.js",
    "demo:reset": "node scripts/reset-demo.js",
    "prod:bootstrap": "node scripts/prod-bootstrap.js",
    "health:watch": "node scripts/health-watch.js",
    "backup": "node scripts/db-backup.js",
    "backup:schedule": "powershell -ExecutionPolicy Bypass -File scripts/schedule-backup.ps1",
    "restore": "node scripts/db-restore.js",
    "test": "set NODE_ENV=test&& node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand",
    "test:smoke": "set NODE_ENV=test&& node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand tests/smoke.workflow.test.js"
  },
  "dependencies": {
    "@prisma/client": "^6.3.1",
    "axios": "^1.7.9",
    "base64-url": "^2.3.3",
    "bcryptjs": "^2.4.3",
    "cookie": "^1.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csurf": "^1.2.2",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "hpp": "^0.2.3",
    "http-status-codes": "^2.3.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "minimatch": "^10.2.4",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "otplib": "^12.0.1",
    "pdfkit": "^0.16.0",
    "pino": "^9.6.0",
    "pino-http": "^10.3.0",
    "prisma": "^6.3.1",
    "qrcode": "^1.5.4",
    "socket.io": "^4.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "supertest": "^7.0.0"
  }
}
