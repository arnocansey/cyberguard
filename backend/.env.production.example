NODE_ENV=production
PORT=5000
APP_VERSION=1.0.0
DATABASE_URL=postgresql://user:pass@host:5432/cybersec?sslmode=require
JWT_ACCESS_SECRET=replace_with_strong_access_secret_24_chars_min
JWT_REFRESH_SECRET=replace_with_strong_refresh_secret_24_chars_min
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=7d
AI_SERVICE_URL=http://ai-service:8000
AI_SERVICE_API_KEY=replace_with_shared_secret
AI_SERVICE_TIMEOUT_MS=5000
AI_TIMEOUT_ALERT_THRESHOLD=10
FRONTEND_ORIGIN=https://your-domain.com
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
TRUST_PROXY=true
# Set ENFORCE_CSRF=true only if you configure CSRF_COOKIE_SAMESITE=none for cross-domain SPA hosting (e.g. Vercel + Render)
ENFORCE_CSRF=false
CSRF_COOKIE_SECURE=true
CSRF_COOKIE_SAMESITE=none
RATE_LIMIT_GENERAL_MAX=300
RATE_LIMIT_AUTH_MAX=20
RATE_LIMIT_UPLOAD_MAX=50
REQUIRE_STRONG_SECRETS=true
LOG_LEVEL=info
SCHEDULER_ENABLED=true
SCHEDULER_TICK_SECONDS=60
SEARCH_JOB_CRON=* * * * *
AUTO_THREAT_SCAN_ENABLED=true
AUTO_THREAT_SCAN_CRON=*/5 * * * *
AUTO_THREAT_SCAN_BATCH_SIZE=200
ALERT_ESCALATION_ENABLED=true
ALERT_ESCALATION_CRON=*/5 * * * *
ALERT_ESCALATION_MINUTES=15
ALERT_ESCALATION_SEVERITIES=HIGH,CRITICAL
ALERT_ESCALATION_TARGET_SEVERITY=CRITICAL
ALERT_ESCALATION_MAX_PER_RUN=100